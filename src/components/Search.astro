---
// Search component using Pagefind
---

<div class="relative">
  <button
    id="search-button"
    class="p-2 text-gray-400 hover:text-primary-900 dark:hover:text-white transition-colors cursor-pointer rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800"
    aria-label="Search"
    title="Search (Ctrl+K)"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>
</div>

<!-- Search Modal -->
<div 
  id="search-modal" 
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
>
  <!-- Backdrop -->
  <div 
    id="search-backdrop" 
    class="absolute inset-0 bg-black/50 backdrop-blur-sm"
  ></div>
  
  <!-- Modal Content -->
  <div class="relative flex items-start justify-center pt-[10vh] px-4">
    <div class="w-full max-w-2xl bg-white dark:bg-gray-900 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">
      <!-- Search Header -->
      <div class="flex items-center gap-3 p-4 border-b border-gray-200 dark:border-gray-800">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search articles..."
          class="flex-1 bg-transparent text-primary-900 dark:text-white placeholder-gray-400 outline-none text-base"
          autocomplete="off"
        />
        <div class="flex items-center gap-2">
          <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 text-[10px] font-mono text-gray-400 bg-gray-100 dark:bg-gray-800 rounded">ESC</kbd>
          <button
            id="search-close"
            class="p-1.5 text-gray-400 hover:text-primary-900 dark:hover:text-white cursor-pointer rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            aria-label="Close search"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Search Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <p id="search-placeholder" class="text-center text-sm text-gray-400 py-8">
          Type to search...
        </p>
      </div>
      
      <!-- Footer -->
      <div class="flex items-center justify-between px-4 py-2 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-200 dark:border-gray-800 text-[10px] text-gray-400">
        <span>Powered by Pagefind</span>
        <div class="flex items-center gap-2">
          <span class="hidden sm:inline">
            <kbd class="px-1 py-0.5 font-mono bg-gray-100 dark:bg-gray-800 rounded">⌘K</kbd> to open
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // Ensure script runs after DOM is ready
  (function() {
    const searchButton = document.getElementById('search-button');
    const searchModal = document.getElementById('search-modal');
    const searchBackdrop = document.getElementById('search-backdrop');
    const searchClose = document.getElementById('search-close');
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    
    let pagefind = null;
    let pagefindLoading = false;
    
    async function loadPagefind() {
      if (pagefind) return pagefind;
      if (pagefindLoading) return null;
      pagefindLoading = true;
      
      try {
        // Try multiple possible paths for pagefind
        const basePath = document.querySelector('base')?.getAttribute('href') || '/blog';
        const paths = [
          basePath + '/pagefind/pagefind.js',
          '/blog/pagefind/pagefind.js',
          '/pagefind/pagefind.js',
        ];
        
        for (const path of paths) {
          try {
            pagefind = await import(path);
            await pagefind.init();
            pagefindLoading = false;
            return pagefind;
          } catch (e) {
            continue;
          }
        }
        
        pagefindLoading = false;
        return null;
      } catch (e) {
        pagefindLoading = false;
        console.warn('Pagefind not available:', e);
        return null;
      }
    }
    
    function openSearch() {
      if (!searchModal) return;
      searchModal.classList.remove('hidden');
      searchInput?.focus();
      document.body.style.overflow = 'hidden';
      loadPagefind();
    }
    
    function closeSearch() {
      if (!searchModal) return;
      searchModal.classList.add('hidden');
      document.body.style.overflow = '';
      if (searchInput) searchInput.value = '';
      if (searchResults) {
        searchResults.innerHTML = '<p class="text-center text-sm text-gray-400 py-8">Type to search...</p>';
      }
    }
    
    searchButton?.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      openSearch();
    });
    
    searchBackdrop?.addEventListener('click', closeSearch);
    searchClose?.addEventListener('click', closeSearch);
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeSearch();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
    });
    
    let debounceTimer = null;
    
    searchInput?.addEventListener('input', function(e) {
      const query = e.target.value;
      
      if (debounceTimer) clearTimeout(debounceTimer);
      
      if (!query || query.length < 2) {
        if (searchResults) {
          searchResults.innerHTML = '<p class="text-center text-sm text-gray-400 py-8">Type to search...</p>';
        }
        return;
      }
      
      // Show loading state
      if (searchResults) {
        searchResults.innerHTML = '<p class="text-center text-sm text-gray-400 py-8">Searching...</p>';
      }
      
      debounceTimer = setTimeout(async function() {
        const pf = await loadPagefind();
        if (!pf) {
          if (searchResults) {
            searchResults.innerHTML = '<p class="text-center text-sm text-gray-400 py-8">Search is not available. Please run <code class="bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded text-xs">npm run build</code> first.</p>';
          }
          return;
        }
        
        try {
          const search = await pf.search(query);
          
          if (search.results.length === 0) {
            if (searchResults) {
              searchResults.innerHTML = '<p class="text-center text-sm text-gray-400 py-8">No results found for "' + query + '"</p>';
            }
            return;
          }
          
          const results = await Promise.all(search.results.slice(0, 10).map(function(r) { return r.data(); }));
          
          if (searchResults) {
            searchResults.innerHTML = results.map(function(result) {
              return '<a href="' + result.url + '" class="block p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer">' +
                '<h3 class="text-sm font-medium text-primary-900 dark:text-white">' + (result.meta.title || 'Untitled') + '</h3>' +
                '<p class="text-xs text-gray-400 dark:text-gray-500 mt-1 line-clamp-2">' + (result.excerpt || '') + '</p>' +
              '</a>';
            }).join('');
          }
        } catch (err) {
          console.error('Search error:', err);
          if (searchResults) {
            searchResults.innerHTML = '<p class="text-center text-sm text-gray-400 py-8">Search error. Please try again.</p>';
          }
        }
      }, 200);
    });
  })();
</script>
