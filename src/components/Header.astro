---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';

const navLinks = [
  { href: '/blog/blog/', label: 'Articles', labelVi: 'Bài viết' },
  { href: '/blog/tags/', label: 'Tags', labelVi: 'Tags' },
  { href: '/blog/categories/', label: 'Categories', labelVi: 'Danh mục' },
];

const socialLinks = {
  github: 'https://github.com/hopny98',
  linkedin: 'https://www.linkedin.com/in/hopny/',
  email: 'mailto:nguyenyhop1999@gmail.com'
};
---

<header class="sticky top-4 z-50 mx-4 md:mx-auto max-w-6xl glass border border-gray-200/60 dark:border-gray-800/60 rounded-2xl shadow-sm transition-all">
  <nav class="w-full px-5 sm:px-6">
    <div class="flex items-center justify-between h-14">
      <!-- Logo (separate from nav, links to home) -->
      <a href="/blog/" class="flex items-center gap-2.5 group cursor-pointer shrink-0 mr-8">
        <div class="w-8 h-8 rounded-lg bg-primary-900 dark:bg-white flex items-center justify-center text-white dark:text-primary-900 font-bold text-sm tracking-tight transition-transform duration-200 group-hover:-translate-y-0.5">
          AI
        </div>
        <span class="font-semibold text-lg text-primary-900 dark:text-white tracking-tight hidden sm:block">
          AI Blog
        </span>
      </a>
      
      <!-- Desktop Navigation (no "Home" — logo already links home) -->
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a 
            href={link.href}
            class="nav-link text-sm text-gray-500 dark:text-gray-400 hover:text-primary-900 dark:hover:text-white font-medium transition-colors cursor-pointer"
            data-en={link.label}
            data-vi={link.labelVi}
          >
            <span class="nav-label-en">{link.label}</span>
            <span class="nav-label-vi hidden">{link.labelVi}</span>
          </a>
        ))}
      </div>
      
      <!-- Right Section -->
      <div class="flex items-center gap-2">
        <!-- Search -->
        <Search />

        <!-- Language Toggle -->
        <button
          id="lang-toggle"
          class="p-2 text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-primary-900 dark:hover:text-white transition-colors cursor-pointer rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 min-w-[36px] text-center"
          aria-label="Toggle language"
          title="Switch language"
        >
          EN
        </button>
        
        <!-- Social Links -->
        <div class="hidden lg:flex items-center gap-1">
          <a 
            href={socialLinks.github}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 text-gray-400 hover:text-primary-900 dark:hover:text-white transition-colors cursor-pointer"
            aria-label="GitHub"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          
          <a 
            href={socialLinks.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 text-gray-400 hover:text-primary-900 dark:hover:text-white transition-colors cursor-pointer"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          
          <a 
            href={socialLinks.email}
            class="p-2 text-gray-400 hover:text-primary-900 dark:hover:text-white transition-colors cursor-pointer"
            aria-label="Email"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
        
        <!-- Theme Toggle -->
        <ThemeToggle />
        
        <!-- Mobile Menu Button -->
        <button 
          id="mobile-menu-button"
          class="md:hidden p-2 text-gray-500 dark:text-gray-400 hover:text-primary-900 dark:hover:text-white cursor-pointer"
          aria-label="Menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-3">
      <div class="flex flex-col gap-1 pt-2 border-t border-gray-200/60 dark:border-gray-800/60">
        {navLinks.map((link) => (
          <a 
            href={link.href}
            class="nav-link px-3 py-2 text-sm text-gray-500 dark:text-gray-400 hover:text-primary-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg font-medium transition-colors cursor-pointer"
            data-en={link.label}
            data-vi={link.labelVi}
          >
            <span class="nav-label-en">{link.label}</span>
            <span class="nav-label-vi hidden">{link.labelVi}</span>
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Language toggle
  const langToggle = document.getElementById('lang-toggle');
  let currentLang = localStorage.getItem('lang') || 'en';

  function applyLanguage(lang) {
    currentLang = lang;
    localStorage.setItem('lang', lang);
    
    if (langToggle) {
      langToggle.textContent = lang === 'en' ? 'VI' : 'EN';
    }

    document.querySelectorAll('.nav-label-en').forEach(el => {
      (el as HTMLElement).classList.toggle('hidden', lang === 'vi');
    });
    document.querySelectorAll('.nav-label-vi').forEach(el => {
      (el as HTMLElement).classList.toggle('hidden', lang === 'en');
    });
    
    // Toggle all elements with data-en / data-vi text
    document.querySelectorAll('[data-lang-en]').forEach(el => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = lang === 'en' ? htmlEl.dataset.langEn! : htmlEl.dataset.langVi!;
    });
  }

  // Apply saved language on load
  applyLanguage(currentLang);
  
  langToggle?.addEventListener('click', () => {
    applyLanguage(currentLang === 'en' ? 'vi' : 'en');
  });
</script>
