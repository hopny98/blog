---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sortedPosts.slice(0, 6);
---

<BaseLayout title="AI Blog — Artificial Intelligence Knowledge" description="Personal blog sharing knowledge about AI, Machine Learning, and cutting-edge technology">
  <Header />
  
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="py-24 lg:py-32 mt-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-primary-900 dark:text-white tracking-tighter leading-[1.1] mb-6">
            <span data-lang-en="Explore the world of" data-lang-vi="Khám phá thế giới">Explore the world of</span>
            <span class="text-accent" data-lang-en="Artificial Intelligence" data-lang-vi="Trí tuệ nhân tạo">Artificial Intelligence</span>
          </h1>
          <p class="text-lg text-gray-500 dark:text-gray-400 mb-10 leading-relaxed max-w-xl" data-lang-en="Sharing knowledge about AI, Machine Learning, Deep Learning, and the latest technologies. From theory to practice, from fundamentals to advanced." data-lang-vi="Chia sẻ kiến thức về AI, Machine Learning, Deep Learning và các công nghệ tiên tiến nhất. Từ lý thuyết đến thực hành, từ cơ bản đến nâng cao.">
            Sharing knowledge about AI, Machine Learning, Deep Learning, and the latest technologies. From theory to practice, from fundamentals to advanced.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a 
              href="/blog/blog/" 
              class="btn-primary inline-flex items-center justify-center gap-2 text-sm"
            >
              <span data-lang-en="Browse all articles" data-lang-vi="Xem tất cả bài viết">Browse all articles</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a 
              href="/blog/tags/" 
              class="btn-secondary inline-flex items-center justify-center text-sm"
            >
              <span data-lang-en="Explore by topic" data-lang-vi="Khám phá theo chủ đề">Explore by topic</span>
            </a>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Featured Posts -->
    <section class="py-16 lg:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
          <div>
            <h2 class="text-2xl font-bold text-primary-900 dark:text-white tracking-tight" data-lang-en="Latest articles" data-lang-vi="Bài viết mới nhất">
              Latest articles
            </h2>
            <p class="mt-1 text-sm text-gray-400 dark:text-gray-500" data-lang-en="Stay updated with the newest AI insights" data-lang-vi="Cập nhật kiến thức mới nhất về AI">
              Stay updated with the newest AI insights
            </p>
          </div>
          <a 
            href="/blog/blog/"
            class="hidden sm:inline-flex items-center text-sm text-gray-500 hover:text-accent font-medium transition-colors cursor-pointer"
          >
            <span data-lang-en="View all" data-lang-vi="Xem tất cả">View all</span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        
        {recentPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {recentPosts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16 border border-dashed border-gray-200 dark:border-gray-800 rounded-xl">
            <p class="text-gray-400 dark:text-gray-500" data-lang-en="No articles yet. Check back soon!" data-lang-vi="Chưa có bài viết nào. Hãy quay lại sau!">
              No articles yet. Check back soon!
            </p>
          </div>
        )}
        
        <div class="mt-10 text-center sm:hidden">
          <a 
            href="/blog/blog/"
            class="inline-flex items-center text-sm text-gray-500 hover:text-accent font-medium transition-colors cursor-pointer"
          >
            <span data-lang-en="View all articles" data-lang-vi="Xem tất cả bài viết">View all articles</span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
    
    <!-- Categories Section -->
    <section class="py-16 border-t border-gray-200 dark:border-gray-800">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-primary-900 dark:text-white tracking-tight" data-lang-en="Topics" data-lang-vi="Chủ đề">
            Topics
          </h2>
          <p class="mt-1 text-sm text-gray-400 dark:text-gray-500" data-lang-en="Explore different areas of AI" data-lang-vi="Khám phá các lĩnh vực trong AI">
            Explore different areas of AI
          </p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: 'Machine Learning', desc: 'From basics to advanced', descVi: 'Từ cơ bản đến nâng cao', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
            { name: 'Deep Learning', desc: 'Neural Networks & Frameworks', descVi: 'Mạng neural & Frameworks', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
            { name: 'NLP', desc: 'Natural Language Processing', descVi: 'Xử lý ngôn ngữ tự nhiên', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
            { name: 'Computer Vision', desc: 'Image & Video Analysis', descVi: 'Phân tích hình ảnh & video', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
          ].map((cat) => (
            <a 
              href={`/blog/categories/${cat.name.toLowerCase().replace(' ', '-')}/`}
              class="p-5 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-accent/30 dark:hover:border-accent/40 hover:shadow-md transition-all group cursor-pointer"
            >
              <div class="w-10 h-10 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center mb-3 group-hover:bg-accent-50 dark:group-hover:bg-accent-900/20 transition-colors">
                <svg class="w-5 h-5 text-gray-500 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={cat.icon} />
                </svg>
              </div>
              <h3 class="text-sm font-semibold text-primary-900 dark:text-white group-hover:text-accent transition-colors">
                {cat.name}
              </h3>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1" data-lang-en={cat.desc} data-lang-vi={cat.descVi}>{cat.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<script>
  // Apply language to page content on load
  function applyPageLanguage() {
    const lang = localStorage.getItem('lang') || 'en';
    document.querySelectorAll('[data-lang-en]').forEach(el => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = lang === 'en' ? htmlEl.dataset.langEn! : htmlEl.dataset.langVi!;
    });
  }
  applyPageLanguage();
  
  // Listen for language changes
  window.addEventListener('storage', (e) => {
    if (e.key === 'lang') applyPageLanguage();
  });
</script>
